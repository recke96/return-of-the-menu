---
interface Props {
    title: string;
}

const { title } = Astro.props;
---

<html lang="de">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body>
        <header>
            <nav>
                <a href="#">Home</a>
            </nav>
        </header>
        <h1>{title}</h1>
        <main>
            <slot />
        </main>
    </body>
</html>
