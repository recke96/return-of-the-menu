---
import FormattedDate from "@components/FormattedDate.astro";
import ThemePicker from "@components/ThemePicker.vue";

interface Props {
  title: string;
}

const today = new Date();
const { title } = Astro.props;
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="generator" content={Astro.generator} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark light" />
    <title>{title}</title>

    <script is:inline>
      // Prevent the FART effect.
      const theme = localStorage.getItem("theme");
      if (theme && theme !== "system") {
        document.documentElement.setAttribute("data-theme", theme);
      }
    </script>
    <script>
      import { $theme } from "@stores/theme";
      $theme.subscribe((value, _) => {
        if (value !== "system") {
          document.documentElement.setAttribute("data-theme", value);
        } else {
          document.documentElement.removeAttribute("data-theme");
        }
      });
    </script>
  </head>

  <body class="prose lg:prose-lg max-w-full">
    <header class="navbar bg-primary text-primary-content">
      <div class="navbar-start"></div>
      <div class="navbar-center h-full align-center">
        <h1 class="text-center text-primary-content">
          <FormattedDate date={today} formatString="EEEE" />
          <br />
          <small class="text-primary-content">
            <FormattedDate date={today} formatString="dd.MM.yyyy" />
          </small>
        </h1>
      </div>
      <div class="navbar-end">
        <ThemePicker client:load/>
      </div>
    </header>
    <main class="container mx-auto mt-4">
      <slot />
    </main>
  </body>
</html>
